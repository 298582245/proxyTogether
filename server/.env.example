# 服务器配置
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=proxy_together
DB_USER=root
DB_PASSWORD=your_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置 (RS256密钥会在首次启动时自动生成)
JWT_EXPIRES_IN=7d

# 同端口正向代理配置
FORWARD_PROXY_ENABLED=false
FORWARD_PROXY_USERNAME=proxy_user
FORWARD_PROXY_PASSWORD=proxy_password
FORWARD_PROXY_DURATION=5
FORWARD_PROXY_FORMAT=txt
FORWARD_PROXY_REMARK=正向代理
FORWARD_PROXY_TIMEOUT=30000
